# LEGEND VAPE STORE — Dashboard env vars
#
# Copy to `.env.local` and fill in.
# Server-only — do NOT prefix with NEXT_PUBLIC_.

# MongoDB connection string from Atlas (or local mongod)
#   https://cloud.mongodb.com → Database → Connect → Drivers → Node.js
MONGODB_URI=

# Database name. Must match the storefront's MONGODB_DB.
MONGODB_DB=legend-vape-store

# Single shared admin password. Anyone with this can edit products.
# For production, replace with a stronger value (32+ chars random).
ADMIN_PASSWORD=
